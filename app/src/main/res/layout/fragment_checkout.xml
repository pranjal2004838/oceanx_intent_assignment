<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_16"
        android:background="@color/surface"
        android:elevation="4dp">

        <Button
            android:id="@+id/back_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:background="?attr/selectableItemBackground"
            android:textSize="@dimen/text_size_24" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Checkout"
            android:textSize="@dimen/text_size_18"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center" />

        <View
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <!-- Checkout Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/content_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16">

            <!-- Order Summary -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_16"
                app:cardCornerRadius="@dimen/product_card_corner"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_16">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Order Summary"
                        android:textSize="@dimen/text_size_16"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="@dimen/spacing_12" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/checkout_items_recycler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginVertical="@dimen/spacing_12" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_8">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Subtotal:"
                            android:textSize="@dimen/text_size_14"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/subtotal_amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0"
                            android:textSize="@dimen/text_size_14"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_8">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Delivery Fee:"
                            android:textSize="@dimen/text_size_14"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0 (Free)"
                            android:textSize="@dimen/text_size_14"
                            android:textColor="@color/success" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_16">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total:"
                            android:textSize="@dimen/text_size_16"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/order_total_amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0"
                            android:textSize="@dimen/text_size_18"
                            android:textStyle="bold"
                            android:textColor="@color/primary" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Delivery Address -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_16"
                app:cardCornerRadius="@dimen/product_card_corner"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_16">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/delivery_address"
                        android:textSize="@dimen/text_size_14"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="@dimen/spacing_12" />

                    <EditText
                        android:id="@+id/delivery_address_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter your address"
                        android:inputType="text"
                        android:minLines="2"
                        android:background="@drawable/edit_text_bg"
                        android:padding="@dimen/spacing_12"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Payment Method -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_16"
                app:cardCornerRadius="@dimen/product_card_corner"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_16">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/payment_method"
                        android:textSize="@dimen/text_size_14"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="@dimen/spacing_12" />

                    <Spinner
                        android:id="@+id/payment_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:entries="@array/payment_methods" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Promo Code -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_24"
                app:cardCornerRadius="@dimen/product_card_corner"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_16">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/promo_code"
                        android:textSize="@dimen/text_size_14"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="@dimen/spacing_12" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/promo_code_input"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:hint="e.g., SAVE10"
                            android:background="@drawable/edit_text_bg"
                            android:padding="@dimen/spacing_12"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:inputType="text"
                            android:layout_marginEnd="@dimen/spacing_8" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/apply_promo_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:text="Apply"
                            android:textAllCaps="false"
                            app:backgroundTint="@color/secondary"
                            app:cornerRadius="@dimen/product_card_corner" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/discount_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Discount Applied: ₹100"
                        android:textColor="@color/success"
                        android:textStyle="bold"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <!-- Order Confirmation -->
    <LinearLayout
        android:id="@+id/confirmation_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_16"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅"
            android:textSize="64sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/order_confirmed"
            android:textSize="@dimen/text_size_24"
            android:textStyle="bold"
            android:textColor="@color/success"
            android:layout_marginTop="@dimen/spacing_16" />

        <TextView
            android:id="@+id/confirmation_order_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Order ID: ORD123456"
            android:textSize="@dimen/text_size_14"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="@dimen/spacing_16" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="@dimen/spacing_16">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total: "
                android:textSize="@dimen/text_size_16"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/confirmation_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹500"
                android:textSize="@dimen/text_size_18"
                android:textStyle="bold"
                android:textColor="@color/primary" />

        </LinearLayout>

        <TextView
            android:id="@+id/confirmation_delivery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estimated Delivery: 15 minutes"
            android:textSize="@dimen/text_size_14"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="@dimen/spacing_12" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/track_order_btn"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="Track Order"
            android:layout_marginTop="@dimen/spacing_32"
            android:textColor="@color/white"
            android:textAllCaps="false"
            app:backgroundTint="@color/primary"
            app:cornerRadius="@dimen/product_card_corner" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/continue_shopping_btn"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="Continue Shopping"
            android:layout_marginTop="@dimen/spacing_12"
            android:textColor="@color/primary"
            android:textAllCaps="false"
            app:strokeColor="@color/primary"
            app:strokeWidth="2dp"
            app:cornerRadius="@dimen/product_card_corner" />

    </LinearLayout>

    <!-- Loading & Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_16"
        android:background="@color/surface"
        android:elevation="8dp">

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/place_order_btn"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/place_order"
            android:textColor="@color/white"
            android:textAllCaps="false"
            app:backgroundTint="@color/primary"
            app:cornerRadius="@dimen/product_card_corner" />

    </LinearLayout>

</LinearLayout>
