<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_16"
        android:background="@color/surface">

        <TextView
            android:id="@+id/delivery_eta_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delivery in 8 mins"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:textSize="@dimen/text_size_18" />

        <TextView
            android:id="@+id/delivery_address_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="123 Main Street, City"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_12"
            android:layout_marginTop="@dimen/spacing_4" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/spacing_12">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/location_demo_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Fetch Location (Demo)"
                android:textAllCaps="false"
                app:backgroundTint="@color/secondary"
                app:cornerRadius="@dimen/product_card_corner" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/view_cart_demo_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Go to Cart"
                android:textAllCaps="false"
                android:layout_marginStart="@dimen/spacing_8"
                app:backgroundTint="@color/primary"
                app:cornerRadius="@dimen/product_card_corner" />

        </LinearLayout>

    </LinearLayout>

    <!-- Search Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface">

        <androidx.appcompat.widget.SearchView
            android:id="@+id/search_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/spacing_8"
            app:queryHint="@string/search_hint" />

    </com.google.android.material.appbar.AppBarLayout>

    <ProgressBar
        android:id="@+id/loading_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Categories -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Categories"
        android:textSize="@dimen/text_size_16"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:padding="@dimen/spacing_16" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/categories_recycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/spacing_8" />

    <!-- Products Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Products"
        android:textSize="@dimen/text_size_16"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:padding="@dimen/spacing_16"
        android:paddingTop="@dimen/spacing_20" />

    <!-- Products Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/products_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/spacing_8"
        android:paddingBottom="@dimen/spacing_16" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📦"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_products"
            android:textSize="@dimen/text_size_16"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="@dimen/spacing_16" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/cart_summary_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_12"
        android:background="@color/surface"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/cart_items_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 items"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/cart_total_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:textSize="@dimen/text_size_16" />

        </LinearLayout>

        <Button
            android:id="@+id/go_checkout_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Go Checkout"
            android:textAllCaps="false"
            android:background="@color/primary"
            android:textColor="@color/white" />

    </LinearLayout>

</LinearLayout>
